# --- Local (Docker Postgres on host port 5433) ---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/healthsync

# --- Supabase (production / shared DB) ---
# Project → Settings → Database → URI. Replace [YOUR-PASSWORD] with the database password.
# Use sslmode=require for TLS (required by Supabase).
# If the password contains @, #, %, etc., URL-encode it (e.g. Python: urllib.parse.quote_plus(password)).
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.nwqiilsixeqmhlqnirzd.supabase.co:5432/postgres?sslmode=require

OPENAI_API_KEY=sk-proj-your-key-here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=15
