# --- Local (Docker Postgres on host port 5433) ---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/healthsync

# --- Render Postgres (production): set automatically via render.yaml fromDatabase ---
# Or paste Internal/External Database URL from Render Dashboard → your Postgres → Connect.

OPENAI_API_KEY=sk-proj-your-key-here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=15
